{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
    "initialCols": 150,
    "initialRows": 50,
    "copyFormatting": "none",
    "copyOnSelect": true,
    "multiLinePasteWarning": false,
    "showTabsInTitlebar": true,
    "showTerminalTitleInTitlebar": true,
    "wordDelimiters": " ()\"';<>!@$^*|+=[]{}",
    "actions": [
        // Split pane vertically
        {
            "command": {
                "action": "splitPane",
                "split": "right"
            },
            "keys": "ctrl+shift+e"
        },
        // Split pane horizontally
        {
            "command": {
                "action": "splitPane",
                "split": "down"
            },
            "keys": "ctrl+shift+o"
        },
        // Duplicate pane
        {
            "command": {
                "action": "splitPane",
                "split": "auto",
                "splitMode": "duplicate"
            },
            "keys": "alt+shift+d"
        },
        // Copy action
        {
            "command": {
                "action": "copy",
                "singleLine": false
            },
            "keys": "ctrl+shift+c"
        },
        // Paste action
        {
            "command": "paste",
            "keys": "ctrl+shift+v"
        },
        // Find action
        {
            "command": "find",
            "keys": "ctrl+shift+f"
        }
    ],
    "newTabMenu": [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles": {
        "defaults": {
            "bellStyle": "none",
            "closeOnExit": "always",
            "cursorShape": "filledBox",
